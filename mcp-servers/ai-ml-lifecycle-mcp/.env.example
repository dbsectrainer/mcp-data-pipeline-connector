# AI/ML Lifecycle MCP — Environment Variables
# BE EASY ENTERPRISES LLC

# MLflow Tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# AWS SageMaker
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerExecutionRole
SAGEMAKER_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Vertex AI
VERTEX_AI_PROJECT=my-gcp-project
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure ML
AZURE_ML_WORKSPACE=my-workspace
AZURE_ML_RESOURCE_GROUP=my-resource-group
AZURE_ML_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Model Registry
MODEL_REGISTRY_BACKEND=local
MODEL_REGISTRY_STORAGE_PATH=./model-artifacts

# Governance & Compliance
GOVERNANCE_POLICY_PATH=./policies
COMPLIANCE_REPORT_OUTPUT=./reports
AUDIT_LOG_PATH=./audit-logs

# Encryption
ENCRYPTION_KEY=
ENCRYPTION_ALGORITHM=aes-256-gcm

# Drift Detection
DRIFT_CHECK_INTERVAL_HOURS=24
DRIFT_ALERT_WEBHOOK_URL=

# Server
MCP_SERVER_PORT=3100
MCP_LOG_LEVEL=info
