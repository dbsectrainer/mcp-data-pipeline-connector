# Enterprise Intelligence MCP Server — Environment Variables
# Copy this file to .env and fill in the values.

# Server configuration
MCP_SERVER_PORT=3200
MCP_SERVER_HOST=127.0.0.1
MCP_LOG_LEVEL=info

# Database connections
DATABASE_PRIMARY_URL=postgresql://user:password@localhost:5432/enterprise_db
DATABASE_ANALYTICS_URL=postgresql://user:password@localhost:5432/analytics_db

# Cloud storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=enterprise-intelligence-data

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=enterprise-data

# External API integrations
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://login.salesforce.com

JIRA_API_TOKEN=
JIRA_BASE_URL=https://your-org.atlassian.net

# Reporting
REPORT_OUTPUT_DIR=./reports
REPORT_TEMPLATE_DIR=./templates

# Risk engine
RISK_ENGINE_MODEL=hybrid
RISK_CONFIDENCE_THRESHOLD=0.85

# Analytics
FORECAST_DEFAULT_PERIODS=4
TREND_MIN_DATA_POINTS=12

# Security
ENCRYPTION_KEY=
API_AUTH_TOKEN=
