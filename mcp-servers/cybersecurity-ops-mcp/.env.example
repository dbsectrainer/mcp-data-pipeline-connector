# ============================================================
# Cybersecurity Operations MCP — Environment Configuration
# BE EASY ENTERPRISES LLC
# ============================================================

# --- SIEM: Splunk ---
SPLUNK_API_URL=https://splunk.example.com:8089
SPLUNK_TOKEN=your-splunk-hec-token
SPLUNK_VERIFY_SSL=true

# --- SIEM: Microsoft Sentinel ---
SENTINEL_WORKSPACE_ID=your-workspace-id
SENTINEL_API_KEY=your-sentinel-api-key
SENTINEL_TENANT_ID=your-azure-tenant-id
SENTINEL_SUBSCRIPTION_ID=your-azure-subscription-id

# --- NVD / CVE Database ---
NVD_API_KEY=your-nvd-api-key
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# --- MITRE ATT&CK ---
MITRE_ATTACK_API_URL=https://attack.mitre.org/api

# --- Threat Intelligence Feeds ---
VIRUSTOTAL_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
OTX_API_KEY=your-otx-api-key

# --- Encryption ---
ENCRYPTION_KEY=your-256-bit-hex-key
ENCRYPTION_ALGORITHM=aes-256-gcm

# --- Server ---
LOG_LEVEL=info
NODE_ENV=production
