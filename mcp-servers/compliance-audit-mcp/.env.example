# Compliance & Audit MCP Server — Environment Variables
# Copy to .env and fill in values

# Server configuration
MCP_SERVER_PORT=3200
MCP_SERVER_HOST=localhost
NODE_ENV=development

# Audit trail storage
AUDIT_TRAIL_PATH=./data/audit-trail
AUDIT_TRAIL_RETENTION_DAYS=2555

# Evidence storage
EVIDENCE_STORAGE_PATH=./data/evidence
EVIDENCE_ENCRYPTION_KEY=

# SSP template directory
SSP_TEMPLATE_PATH=./templates/ssp

# External integrations (optional)
GRC_PLATFORM_URL=
GRC_PLATFORM_API_KEY=
VULNERABILITY_SCANNER_URL=
VULNERABILITY_SCANNER_API_KEY=

# Notification settings
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
