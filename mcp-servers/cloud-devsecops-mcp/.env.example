# =============================================================================
# Cloud & DevSecOps MCP Server — Environment Configuration
# BE EASY ENTERPRISES LLC
# =============================================================================

# --- AWS Configuration ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_GOVCLOUD_REGION=us-gov-west-1
AWS_ACCOUNT_ID=123456789012

# --- Azure Configuration ---
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# --- GCP Configuration ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_PATH=/path/to/service-account-key.json
GCP_REGION=us-central1

# --- Kubernetes Configuration ---
KUBECONFIG=/path/to/.kube/config
K8S_CONTEXT=default

# --- Container Registry Configuration ---
CONTAINER_REGISTRY_URL=your-registry-url
CONTAINER_REGISTRY_USERNAME=your-username
CONTAINER_REGISTRY_PASSWORD=your-password

# --- Security & Compliance ---
FEDRAMP_BOUNDARY=high
CIS_BENCHMARK_VERSION=1.5.0
NIST_FRAMEWORK_VERSION=1.1

# --- Server Configuration ---
LOG_LEVEL=info
DRY_RUN_DEFAULT=true
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_MS=300000
