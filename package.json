{
  "name": "mcp-data-pipeline-connector",
  "version": "1.0.0",
  "description": "Universal data connector for CSV, Postgres, and REST APIs via DuckDB",
  "author": "dbsectrainer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbsectrainer/mcp-data-pipeline-connector.git"
  },
  "homepage": "https://github.com/dbsectrainer/mcp-data-pipeline-connector#readme",
  "type": "module",
  "bin": {
    "mcp-data-pipeline-connector": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "data",
    "sql",
    "duckdb"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src tests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.0-r.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
